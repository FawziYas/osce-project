# ──────────────────────────────────────────────────────────────
# Django Environment
# ──────────────────────────────────────────────────────────────
# Set to 'production' on your server
DJANGO_ENV=development

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production-use-a-real-secret-key

# ──────────────────────────────────────────────────────────────
# Database (production only — development uses SQLite)
# ──────────────────────────────────────────────────────────────
# Option 1: Single DATABASE_URL — recommended for Azure
#   Use port 6432 (PgBouncer) instead of 5432 when PgBouncer is enabled.
#   Append ?sslmode=require — Azure PostgreSQL Flexible Server requires SSL.
# DATABASE_URL=postgresql://osce_app:PASSWORD@yourserver.postgres.database.azure.com:6432/osce_production?sslmode=require

# Option 2: Individual vars
# DB_NAME=osce_production
# DB_USER=osce_app
# DB_PASSWORD=strong_8+_char_password
# DB_HOST=yourserver.postgres.database.azure.com
# DB_PORT=6432
# DB_SSLMODE=require  # 'require' for Azure, 'prefer' for local dev with PG

# ──────────────────────────────────────────────────────────────
# Hosts & Security (production only)
# ──────────────────────────────────────────────────────────────
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True

# ──────────────────────────────────────────────────────────────
# Redis cache (optional — improves performance at scale)
# ──────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/1

# ──────────────────────────────────────────────────────────────
# Celery async task queue (optional — for non-blocking audit writes)
# When empty, audit logs are written synchronously (safe fallback).
# Reuse the same Redis instance on a different DB number.
# ──────────────────────────────────────────────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────
# Sentry error tracking (optional — free tier at sentry.io)
# ──────────────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ──────────────────────────────────────────────────────────────
# Admin & Security
# ──────────────────────────────────────────────────────────────
# SECRET_ADMIN_URL=my-secret-admin-path
# DEFAULT_USER_PASSWORD=change-default-password
# TRUSTED_PROXIES=127.0.0.1
