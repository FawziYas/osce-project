# ──────────────────────────────────────────────────────────────
# Django Environment
# ──────────────────────────────────────────────────────────────
# Set to 'production' on your server
DJANGO_ENV=development

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production-use-a-real-secret-key

# ──────────────────────────────────────────────────────────────
# Database (production only — development uses SQLite)
# ──────────────────────────────────────────────────────────────
# Option 1: Single DATABASE_URL (Railway, Render, Heroku)
# DATABASE_URL=postgresql://user:password@host:5432/osce_prod

# Option 2: Individual vars
# DB_NAME=osce_prod
# DB_USER=osce
# DB_PASSWORD=strong-password-here
# DB_HOST=localhost
# DB_PORT=5432

# ──────────────────────────────────────────────────────────────
# Hosts & Security (production only)
# ──────────────────────────────────────────────────────────────
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True

# ──────────────────────────────────────────────────────────────
# Redis cache (optional — improves performance at scale)
# ──────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/1

# ──────────────────────────────────────────────────────────────
# Sentry error tracking (optional — free tier at sentry.io)
# ──────────────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ──────────────────────────────────────────────────────────────
# Admin & Security
# ──────────────────────────────────────────────────────────────
# SECRET_ADMIN_URL=my-secret-admin-path
# DEFAULT_USER_PASSWORD=change-default-password
# TRUSTED_PROXIES=127.0.0.1
